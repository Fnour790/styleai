# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://styleai:styleai@localhost:5432/styleai

# ─── Qdrant Vector DB ───────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=wardrobe_items

# ─── Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── HuggingFace ────────────────────────────────────
HF_TOKEN=hf_your-token-here

# ─── App ─────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── Weather (Open-Meteo is free, no key needed) ────
WEATHER_CACHE_TTL_SECONDS=1800
